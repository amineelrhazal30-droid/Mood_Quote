# Mood Tracker — Environment Variables
#
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit .env to Git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# Google Gemini API key
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project REST endpoint for the "moods" table
# Format: https://<project-ref>.supabase.co/rest/v1/moods
SUPABASE_URL=https://your-project.supabase.co/rest/v1/moods

# Supabase anon/publishable key (safe to use client-side, but keep it out of Git)
SUPABASE_ANON_KEY=your_supabase_anon_key_here
